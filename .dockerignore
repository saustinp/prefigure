# Build artifacts that should not pollute the Docker context
build/
.venv/
*.egg-info/
**/__pycache__/
**/*.pyc

# Editor / OS
.vscode/
.idea/
.DS_Store

# Git history (not needed inside the image)
.git/
.gitignore

# Local dev clutter
*.perf
*.data
*.data.old
folded_stacks.txt
implicit_script.txt
pruned_trace.json
prefig_profiling.png
profiling_results*.png
out.perf
implicit.perf

# Notes and research files
*.md
!README.md
build_deploy_convo.txt
last_convo.md
notes.md
notes2.md
todo_changes.md
resume_readme.md

# Conversation captures
*.jsonl

# Output examples (regenerated by the C++ binding test inside the container)
prefig/resources/examples/output_cpp/
prefig/resources/examples/output_python/
examples/output/

# Anything in webdemo's static dir is fine; nothing here to exclude.
